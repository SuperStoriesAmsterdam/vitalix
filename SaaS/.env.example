# ══════════════════════════════════════════════════════════════════
# [PRODUCT NAME] — Environment Variables
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Never commit .env to git — only .env.example.
# Every variable listed here must have a value in production.
# ══════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
APP_VERSION=1.0.0
APP_BASE_URL=https://[product].superstories.nl
APP_SECRET_KEY=                    # Used for signing magic link tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
PRODUCT_ID=                        # e.g. "voicereflect", "tth", "superads" — must match licence key

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/[product]

# ── Redis (only if product uses ARQ background jobs) ─────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── LLM (only if product uses AI features) ──────────────────────
# LLM_PROVIDER=openai              # openai | anthropic | ollama | compatible
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=                    # only for ollama or compatible endpoints
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── File storage — Cloudflare R2 (only if product handles files) ─
# R2_ENDPOINT_URL=https://[account-id].r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://media.superstories.com

# ── Email — Resend (only if product sends email) ────────────────
# RESEND_API_KEY=
# EMAIL_FROM=noreply@superstories.nl

# ── Billing — Stripe (only if product has paid tiers) ───────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# ── Licence ──────────────────────────────────────────────────────
LICENCE_KEY=                       # JWT licence key — generated by SuperStories keygen
SUPERSTORIES_PUBLIC_KEY=           # Ed25519 public key for licence validation

# ── Product-specific variables ───────────────────────────────────
# Add product-specific env vars below this line.
# For each variable, add a comment explaining what it is and where to get the value.
#
# Example:
# DEEPGRAM_API_KEY=               # Transcription service — get from https://console.deepgram.com
# META_APP_ID=                    # Meta Marketing API — get from https://developers.facebook.com
