# ─────────────────────────────────────────────────────────────────────────────
# Vitalix — omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in.
# NOOIT .env committen naar Git — alleen .env.example
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
SECRET_KEY=vervang-dit-door-een-willekeurige-lange-string-minimaal-32-tekens
ENVIRONMENT=development   # development | production

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL verbindingsstring
DATABASE_URL=postgresql://vitalix:vitalix@localhost:5432/vitalix

# ── Redis (ARQ background jobs) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Withings ──────────────────────────────────────────────────────────────────
# Maak een app aan op https://account.withings.com/partner/add
WITHINGS_CLIENT_ID=jouw-withings-client-id
WITHINGS_CLIENT_SECRET=jouw-withings-client-secret
WITHINGS_REDIRECT_URI=http://localhost:8000/withings/callback

# ── Polar ─────────────────────────────────────────────────────────────────────
# Registreer op https://admin.polaraccesslink.com
POLAR_CLIENT_ID=jouw-polar-client-id
POLAR_CLIENT_SECRET=jouw-polar-client-secret
POLAR_REDIRECT_URI=http://localhost:8000/polar/callback

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# API key van https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-opus-4-5   # claude-opus-4-5 | claude-sonnet-4-5 | claude-haiku-4-5

# ── E-mail (Resend) ───────────────────────────────────────────────────────────
# Alleen nodig in Sprint 1 wanneer magic links per e-mail worden verstuurd.
# In Sprint 0 worden links gelogd naar de console.
# API key van https://resend.com
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@vitalix.app

# ── Whoop ─────────────────────────────────────────────────────────────────────
# Registreer op https://developer.whoop.com
WHOOP_CLIENT_ID=jouw-whoop-client-id
WHOOP_CLIENT_SECRET=jouw-whoop-client-secret
WHOOP_REDIRECT_URI=http://localhost:8000/whoop/callback
