# ── Database ──────────────────────────────────────────────────
# Lokaal: postgresql://vitalix:vitalix@localhost:5432/vitalix
# Productie (Coolify): postgresql://vitalix:${DB_PASSWORD}@db:5432/vitalix
DATABASE_URL=postgresql://vitalix:vitalix@localhost:5432/vitalix

# Alleen nodig in docker-compose.yml productie — wachtwoord voor de db-container
DB_PASSWORD=

# ── Redis (ARQ background jobs) ───────────────────────────────
# Lokaal: localhost
# Productie (Coolify): redis (naam van de Docker service)
REDIS_HOST=localhost
REDIS_PORT=6379

# ── App ───────────────────────────────────────────────────────
APP_SECRET_KEY=vervang-dit-met-een-willekeurige-string-van-32-tekens
APP_BASE_URL=http://localhost:8000
PRODUCT_ID=vitalix
APP_VERSION=0.1.0

# ── Email (Resend) ────────────────────────────────────────────
# Aanvragen via: https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@vitalix.com

# ── Withings API ──────────────────────────────────────────────
# Aanvragen via: https://developer.withings.com
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:8000/withings/callback
# Productie: https://vitalix.com/withings/callback

# ── Oura API ──────────────────────────────────────────────────
# Personal Access Token via: https://cloud.ouraring.com/personal-access-tokens
# Wordt per gebruiker encrypted opgeslagen in de database — geen env var nodig.
